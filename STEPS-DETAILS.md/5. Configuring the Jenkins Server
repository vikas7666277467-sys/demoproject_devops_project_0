# Replace the Jenkinsfile

Replace the existing Jenkinsfile with the following version.

```groovy
pipeline {

    agent any

    environment {

        IMAGE_NAME = "demoproject/flask-app"
        TAG = "${BUILD_NUMBER}"
        KUBECONFIG = "/var/lib/jenkins/.kube/config"

    }

    stages {

        stage('Checkout Source Code') {

            steps {
                checkout scm
            }

        }

        stage('Verify Workspace') {

            steps {

                sh '''
                pwd
                ls -lrt
                '''

            }

        }

        stage('Build Docker Image') {

            steps {

                sh '''
                docker build -t $IMAGE_NAME:$TAG application/
                docker tag $IMAGE_NAME:$TAG $IMAGE_NAME:latest
                '''

            }

        }

        stage('Docker Login') {

            steps {

                withCredentials([
                    usernamePassword(
                        credentialsId: 'dockerhub-creds',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )
                ]) {

                    sh '''
                    echo "$DOCKER_PASS" | docker login \
                    -u "$DOCKER_USER" \
                    --password-stdin
                    '''

                }

            }

        }

        stage('Push Docker Image') {

            steps {

                sh '''
                docker push $IMAGE_NAME:$TAG
                docker push $IMAGE_NAME:latest
                '''

            }

        }

        stage('Verify Kubernetes Cluster') {

            steps {

                sh '''
                export KUBECONFIG=$KUBECONFIG
                kubectl get nodes
                '''

            }

        }

        stage('Deploy Application') {

            steps {

                sh '''

                export KUBECONFIG=$KUBECONFIG

                if kubectl get deployment flask-deployment >/dev/null 2>&1
                then

                    echo "Deployment already exists"

                    kubectl set image deployment/flask-deployment \
                    flask=$IMAGE_NAME:$TAG

                else

                    echo "First Deployment"

                    kubectl apply -f kubernetes/namespace.yaml

                    kubectl apply -f kubernetes/deployment.yaml

                    kubectl apply -f kubernetes/service.yaml

                    kubectl set image deployment/flask-deployment \
                    flask=$IMAGE_NAME:$TAG

                fi

                '''

            }

        }

        stage('Wait For Rollout') {

            steps {

                sh '''

                export KUBECONFIG=$KUBECONFIG

                kubectl rollout status deployment/flask-deployment \
                --timeout=300s

                '''

            }

        }

        stage('Verify Deployment') {

            steps {

                sh '''

                export KUBECONFIG=$KUBECONFIG

                echo "========== Deployments =========="

                kubectl get deployment

                echo "========== Pods =========="

                kubectl get pods -o wide

                echo "========== Services =========="

                kubectl get svc

                echo "========== Images =========="

                kubectl describe deployment flask-deployment | grep Image

                '''

            }

        }

    }

}
